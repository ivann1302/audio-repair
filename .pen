              "name": "maH2",
              "fill": "#111111",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "МЕХАНИКА: ГДЕ ЯПОНЦЫ\nНЕ ПОЖАЛЕЛИ ДЕНЕГ",
              "lineHeight": 0.95,
              "fontFamily": "Anton",
              "fontSize": 26,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "8AuFJ",
              "name": "maP1",
              "fill": "#444444",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Лентопротяжный механизм GX-747 построен на закрытой петле — скорость ленты контролируется двумя независимыми датчиками. Большинство производителей того времени ставили один.",
              "lineHeight": 1.9,
              "fontFamily": "Crimson Text",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
