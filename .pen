                      "lineHeight": 0.7,
                      "fontFamily": "Anton",
                      "fontSize": 64,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "REzSY",
                      "name": "artQuoteText",
                      "fill": "#FAFAFA",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Когда вскрываешь GX-747, первое ощущение — это попал на завод, а не в мастерскую. Всё подогнано так, будто делали для космоса.",
                      "lineHeight": 1.7,
                      "fontFamily": "Crimson Text",
                      "fontSize": 18,
                      "fontWeight": "normal",
